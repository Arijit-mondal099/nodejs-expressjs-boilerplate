.prettierignore
.eslintcache
eslint.config.js
commitlint.config.js

# Docker itself
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Docs
README.md
CLAUDE.md
*.md

# OS
.DS_Store
Thumbs.db

